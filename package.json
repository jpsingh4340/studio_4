{
  "name": "rentmate",
  "version": "1.5.0",
  "private": true,
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@heroicons/react": "^2.2.0",
    "@mui/material": "^7.1.2",
    "@playwright/mcp": "^0.0.41",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.0",
    "axios": "^1.10.0",
    "baseline-browser-mapping": "^2.10.10",
    "bootstrap": "^5.3.7",
    "bootstrap-icons": "^1.13.1",
    "caniuse-lite": "^1.0.30001781",
    "chart.js": "^4.5.0",
    "date-fns": "^4.1.0",
    "dompurify": "^3.2.7",
    "firebase": "^11.9.1",
    "firebase-admin": "^13.4.0",
    "firebase-functions": "^6.3.2",
    "framer-motion": "^12.23.22",
    "html-to-image": "^1.11.13",
    "html5-qrcode": "^2.3.8",
    "qrcode.react": "^4.2.0",
    "react": "^19.1.0",
    "react-bootstrap": "^2.10.10",
    "react-bootstrap-icons": "^1.11.6",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^19.1.0",
    "react-icons": "^5.5.0",
    "react-router": "^7.6.2",
    "react-router-dom": "^6.30.3",
    "react-scripts": "^5.0.1",
    "react-toastify": "^11.0.5",
    "recharts": "^2.15.4",
    "styled-components": "^6.1.19",
    "web-vitals": "^5.0.3"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "build:ci": "DISABLE_ESLINT_PLUGIN=true GENERATE_SOURCEMAP=false react-scripts build",
    "test": "react-scripts test --watchAll=false",
    "test:ci": "CI=true react-scripts test --coverage --watchAll=false --passWithNoTests --maxWorkers=2",
    "eject": "react-scripts eject",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx --max-warnings=0",
    "lint:fix": "eslint src --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "security:audit": "npm audit --audit-level=moderate",
    "security:fix": "npm audit fix",
    "security:scan": "eslint src --config .eslintrc.security.json --ext .js,.jsx,.ts,.tsx",
    "security:check": "npm run security:audit && npm run security:scan",
    "build:secure": "npm run security:check && npm run build:ci",
    "test:coverage": "npm run test:ci",
    "test:watch": "react-scripts test"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "ajv": "^8.17.1",
    "ajv-keywords": "^5.1.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-security": "^2.1.1",
    "identity-obj-proxy": "^3.0.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "schema-utils": "^4.3.2",
    "tailwindcss": "^4.1.10"
  }
}
